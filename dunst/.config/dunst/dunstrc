[global]

    monitor = 0

    follow = none

    # width = (100, 300)
    # height = (10, 300)
    origin = top-right

    # Offset from the origin
    # NOTE: Dunst from version 1.11 and older use this alternative notation
    # offset = 10x50
    offset = 5x40

    scale = 0

    notification_limit = 10

    progress_bar = true
    progress_bar_height = 14
    progress_bar_frame_width = 0
    progress_bar_min_width = 100
    progress_bar_max_width = 300
    progress_bar_corner_radius = 50

    icon_corner_radius = 0

    indicate_hidden = yes

    transparency = 0

    separator_height = 6

    padding = 10
    horizontal_padding = 8
    text_icon_padding = 12

    frame_width = 1
    frame_color = "#a0a0a0"

    gap_size = 6
    separator_color = frame

    sort = yes

    ### Text ###

    font = FiraMono Nerd Font 12
    line_height = 0

    markup = full

    # The format of the message.  Possible variables are:
    #   %a  appname
    #   %s  summary
    #   %b  body
    #   %i  iconname (including its path)
    #   %I  iconname (without its path)
    #   %p  progress value if set ([  0%] to [100%]) or nothing
    #   %n  progress value if set without any extra characters
    #   %%  Literal %
    # Markup is allowed
    format = "<span foreground='#F0C674' weight='bold'>%a • </span><b>%s</b>\n%b"

    alignment = left
    vertical_alignment = center
    show_age_threshold = -1

    ellipsize = middle

    ignore_newline = no

    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    ### Icons ###

    enable_recursive_icon_lookup = true

    icon_theme = kora
    icon_position = right

    min_icon_size = 32
    max_icon_size = 128

    icon_path = /usr/share/icons/gnome/16x16/status/:/usr/share/icons/gnome/16x16/devices/

    ### History ###

    sticky_history = yes
    history_length = 30

    ### Misc/Advanced ###

    dmenu = /usr/bin/dmenu -l 10 -p dunst:
    browser = /usr/bin/xdg-open

    always_run_script = true
    title = Dunst
    class = Dunst

    corner_radius = 10
    ignore_dbusclose = false

    ### Wayland ###
    # Uncomment this if you want to let notifications appear under fullscreen
    # applications (default: overlay)
    # layer = top
    force_xwayland = false

    ### Legacy
    force_xinerama = false

    ### mouse

    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[experimental]
    per_monitor_dpi = false


[urgency_low]
    background = "#282a2e"
    foreground = "#c5c8c6"
    frame_color = "#282a2e"
    timeout = 20

[urgency_normal]
    background = "#282a2e"
    foreground = "#c5c8c6"
    frame_color = "#282a2e"
    timeout = 20

    default_icon = none

[urgency_critical]
    background = "#282a2e"
    foreground = "#c5c8c6"
    frame_color = "#282a2e"
    timeout = 0
    default_icon = none
